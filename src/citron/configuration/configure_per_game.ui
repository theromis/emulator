  <property name="templateStyleSheet" stdset="0">
   <string>
QDialog {
    background-color: %%BACKGROUND_COLOR%%;
}

#info_panel, #tabButtonsContainer {
    background-color: transparent;
}

#info_panel QLineEdit {
    background-color: %%TERTIARY_BG_COLOR%%;
    border: 1px solid %%SECONDARY_BG_COLOR%%;
    border-radius: 4px;
    padding: 2px 10px;
    color: %%TEXT_COLOR%%;
}

#dev_box, #version_box, #id_box {
    background-color: %%SECONDARY_BG_COLOR%%;
    border-radius: 8px;
    padding: 5px;
}

#label_dev_header, #label_version_header, #label_id_header {
    color: %%TEXT_COLOR_DIM%%;
    font-weight: bold;
    font-size: 10px;
    text-transform: uppercase;
}

#game_title_label {
    padding: 10px 0px;
    color: %%TEXT_COLOR%%;
}

#label_console_hints {
    color: %%TEXT_COLOR_DIM%%;
    font-size: 11px;
}

/* Wireframe Action Buttons */
#info_panel QPushButton {
    background-color: transparent;
    border: 1px solid %%ACCENT_COLOR%%;
    border-radius: 6px;
    color: %%ACCENT_COLOR%%;
    font-weight: bold;
    height: 34px;
}

#info_panel QPushButton:hover {
    background-color: rgba(%%ACCENT_COLOR_R%%, %%ACCENT_COLOR_G%%, %%ACCENT_COLOR_B%%, 30);
}

/* Vertical Tab Buttons */
#aestheticTabButton {
    background-color: transparent;
    border: none;
    color: %%TEXT_COLOR_DIM%%;
    text-align: left;
    padding: 12px 20px;
    font-weight: bold;
    font-size: 13px;
}

#aestheticTabButton:checked {
    color: %%TEXT_COLOR%%;
    border-left: 3px solid %%ACCENT_COLOR%%;
    background-color: rgba(%%ACCENT_COLOR_R%%, %%ACCENT_COLOR_G%%, %%ACCENT_COLOR_B%%, 20);
}

#aestheticTabButton:hover:!checked {
    color: %%TEXT_COLOR%%;
    background-color: rgba(%%ACCENT_COLOR_R%%, %%ACCENT_COLOR_G%%, %%ACCENT_COLOR_B%%, 10);
}

#full_info_button {
    background: transparent;
    border: none;
    color: %%TEXT_COLOR_DIM%%;
}

#full_info_button:hover {
    color: %%ACCENT_COLOR%%;
}

/* Accent-Aware ScrollBars (Referencing Game List) */
QScrollBar:vertical {
    border: 1px solid %%SECONDARY_BG_COLOR%%;
    background: transparent;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: %%ACCENT_COLOR%%;
    min-height: 20px;
    border-radius: 5px;
    border: 1px solid %%SECONDARY_BG_COLOR%%;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
    height: 0px;
}

QScrollArea {
    border: none;
    background: transparent;
}

QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}
   </string>
